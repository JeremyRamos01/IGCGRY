rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // FUNCIÓN: Verifica si el usuario conectado es uno de los administradores autorizados
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "iglesiaevangelicacasagranrey@gmail.com" || 
        request.auth.token.email == "ramosjeremy023@gmail.com"
      );
    }

    // COLECCIÓN: EVENTOS
    // Cualquiera puede leer (ver) los eventos.
    // SOLO los administradores pueden crear, editar o borrar eventos.
    match /eventos/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COLECCIÓN: CHAT
    // Es un foro libre: cualquiera puede leer y escribir.
    // Nota: El contenido se borra periódicamente según las normas.
    match /chatMessages/{document=**} {
      allow read, write: if true;
    }

    // COLECCIÓN: CONFIG (Estado en Vivo)
    // Cualquiera puede leer el estado del En Vivo.
    // Solo los administradores pueden modificarlo.
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // COLECCIÓN: MENSAJES DE CONTACTO
    // Cualquiera puede enviar (crear) un mensaje de contacto.
    // Solo los administradores pueden leerlos, marcarlos como leídos o eliminarlos.
    match /contactMessages/{document} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
